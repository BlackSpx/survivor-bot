# ─────────────────────────────────────────────────────────────
# Survivor Bot — environment configuration
# Copy this file to ".env" and fill in your own values.
# ─────────────────────────────────────────────────────────────

# Your Discord bot token (Discord Developer Portal → Your App → Bot → Token)
DISCORD_BOT_TOKEN=your-discord-bot-token-here

# Steam Web API key (https://steamcommunity.com/dev/apikey)
STEAM_API_KEY=your-steam-web-api-key-here

# Google Gemini API key for Survivor's personality (https://aistudio.google.com/apikey)
GEMINI_API_KEY=your-gemini-api-key-here

# The numeric ID of the #achievements channel where the bot posts. This is also
# the ONLY channel where ! commands work, and it's commands-only: any message
# that doesn't start with "!" is deleted on sight (give the bot the
# "Manage Messages" permission there so it can). ! commands also still work in DMs.
# Leave blank to skip the restriction and allow commands anywhere (e.g. pre-setup).
# (Enable Developer Mode in Discord → right-click the channel → Copy Channel ID)
ACHIEVEMENT_CHANNEL_ID=123456789012345678

# The ONE channel where Survivor is allowed to talk. He replies to every message
# in this channel and stays completely silent in all other channels (and DMs).
# Only LINKED players may talk here — unlinked users' messages are deleted with a
# nudge to !link first. Anti-spam: each linked user gets 5 messages per rolling
# hour; once they're spent, extra messages are deleted with a quick notice (needs
# "Manage Messages" too). Leave blank to disable conversation entirely.
# (Developer Mode → right-click the channel → Copy Channel ID)
SURVIVOR_CHAT_CHANNEL_ID=

# ── Game voice channel (optional) ────────────────────────────────────────────
# The voice channel your group games in. When set, the bot tracks how long each
# LINKED player spends in it and awards bonus points at cumulative-hour
# milestones (Voice Newbie → Voice Legend), announced in the achievement channel.
# Leave blank to disable voice tracking entirely.
# (Developer Mode → right-click the voice channel → Copy Channel ID)
GAME_VOICE_CHANNEL_ID=

# "true" to DM unlinked users who join the game voice channel and then disconnect
# them if they haven't linked within VOICE_LINK_GRACE_SECONDS. Needs the
# "Move Members" permission to disconnect. Default false (just track, don't kick).
VOICE_KICK_UNLINKED=false

# Seconds an unlinked voice joiner gets to run !link before being kicked (only
# matters when VOICE_KICK_UNLINKED=true). Default = 120.
VOICE_LINK_GRACE_SECONDS=120

# Steady "drip" reward for time in voice: a linked player earns
# VOICE_POINTS_PER_INTERVAL points for every VOICE_POINTS_INTERVAL_MIN minutes of
# cumulative voice time (on top of the big hour milestones, Voice Newbie → Legend).
# Default 3 pts / 10 min (≈18/hr). Set VOICE_POINTS_PER_INTERVAL=0 to disable the
# drip and keep only the hour milestones. (Whether the drip is announced or silent
# is controlled by VOICE_DRIP_ANNOUNCE below.)
VOICE_POINTS_PER_INTERVAL=3
VOICE_POINTS_INTERVAL_MIN=10

# "true" (default) makes each voice session post ONE message in the achievement
# channel and edit it in place as the drip total climbs ("+3… +6… +9 pts this
# session"), then finalize to a summary when the player leaves — no per-interval
# spam. Set "false" to keep the drip fully silent (points still accrue).
VOICE_DRIP_ANNOUNCE=true

# Initial Discord-ID → SteamID64 mapping, comma separated.
# Format:  discordId:steamId64,discordId:steamId64
# You can also link players later with the  !link <steamid64>  command.
# Example: 111111111111111111:76561197960287930,222222222222222222:76561198000000000
STEAM_IDS=

# (Optional) How often to poll Steam, in milliseconds. Default = 300000 (5 minutes).
POLL_INTERVAL_MS=300000

# (Optional, for hosting) Absolute path for the SQLite database file. Set this to
# a persistent volume so data survives redeploys. On Railway, mount a volume at
# /data and set:  DATABASE_PATH=/data/survivor.db
# Leave blank for local development (defaults to ./survivor.db).
DATABASE_PATH=

# ── Bot owner (optional) ─────────────────────────────────────────────────────
# Tell Survivor who created/runs him. When configured, he'll say so (in
# character) if someone asks "who owns the bot?" — and stays quiet otherwise.
# All three are optional; set any combination.
OWNER_NAME=
# Your Discord user ID (Developer Mode → right-click yourself → Copy User ID).
# When set, Survivor mentions you as a clickable link.
OWNER_DISCORD_ID=
# Your Steam — a name or profile URL, shown as plain text.
OWNER_STEAM=
# "true" to actually ping you when Survivor names you. Default false (the
# mention still shows as a link, it just won't notify you every time).
OWNER_PING=false

# ── Admin lock ───────────────────────────────────────────────────────────────
# Who may run admin commands: !backup, !addpoints, !setpoints, !prizefor.
# Comma-separated Discord user IDs (Developer Mode → right-click → Copy User ID).
# When set, ONLY these users qualify — server "Administrator" permission no
# longer counts. Leave blank to fall back to the Administrator permission.
# If blank, OWNER_DISCORD_ID (above) is used as the admin if it's set.
# Example: 111111111111111111,222222222222222222
ADMIN_DISCORD_IDS=

# Points a player must reach before they can claim an admin-set prize (!prize).
# Default = 500.
PRIZE_POINTS_THRESHOLD=500

# ── Optional feature toggles ─────────────────────────────────────────────────

# (Optional) Channel for health alerts (Steam/Gemini failures). Falls back to
# the achievement channel if blank.
LOG_CHANNEL_ID=

# Minimum gap between a single user's chat replies, in ms (anti-spam / cost
# control for the chat channel). Default = 4000 (4 seconds).
CHAT_COOLDOWN_MS=4000

# Announce in the achievement channel when someone boots up a tracked game.
# "true" to enable. Default off (can be chatty).
NOW_PLAYING_ENABLED=false

# Post a weekly recap (~every 7 days) of who earned the most. "true" to enable.
RECAP_ENABLED=false

# How to treat achievements a player ALREADY has the first time they're seen:
#   false (default) = baseline them silently, only NEW unlocks earn points.
#   true            = count their existing achievements as points right away
#                     (one summary message + roles, no per-achievement spam).
# (Applies to The Forest / Sons of the Forest only. Other games via
#  TRACK_ALL_GAMES are ALWAYS baselined silently — no retroactive points.)
BACKFILL_EXISTING=false

# Also count achievements from OTHER games (not just the two Forest games). When
# "true", the bot checks each player's recently-played games each poll and awards
# +10 (plus the usual bonuses) for new unlocks in any of them, announced with the
# game's name. A game's existing achievements are baselined silently the first
# time it's seen, so turning this on never dumps a back-catalogue in as points.
# Default off (keeps Steam API usage low and the feed Forest-focused).
TRACK_ALL_GAMES=false
